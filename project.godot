;   param=value ; assign values to parameters

config_version=5

[application]

config/name="GouDaoTV"
config/version="1.0.2"
run/main_scene="res://tv.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
run/max_fps=60
boot_splash/image="uid://dcm003vql707k"
config/icon="uid://bvfaa8anwkoyu"
config/windows_native_icon="res://ress/logo.ico"
boot_splash/minimum_display_time=5000

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=4
window/size/always_on_top=true
window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="GDTV"

